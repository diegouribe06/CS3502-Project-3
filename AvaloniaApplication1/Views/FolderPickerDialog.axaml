<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AvaloniaApplication1.Models"
        mc:Ignorable="d"
        d:DesignWidth="520"
        d:DesignHeight="620"
        x:Class="AvaloniaApplication1.Views.FolderPickerDialog"
        x:CompileBindings="False"
        Title="Select Destination Folder"
        Width="520"
        Height="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <TextBlock x:Name="SelectedPathTextBlock"
                   Text="Select a destination folder"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TreeView x:Name="FolderTreeView"
                  Grid.Row="1">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="models:ListableItem" ItemsSource="{Binding DirectoryChildren}">
                    <TextBlock Text="{Binding Name}"/>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    MinWidth="110"
                    />
            <Button x:Name="SelectButton"
                    Content="Select Folder"
                    MinWidth="110"
                    IsEnabled="False"
                    IsDefault="True"
                    />
        </StackPanel>
    </Grid>
</Window>



